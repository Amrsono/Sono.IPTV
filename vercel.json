{
  "version": 2,
  "name": "sono-player",
  "buildCommand": "",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/stream",           "destination": "https://REPLACE_WITH_YOUR_BACKEND_URL/stream" },
    { "source": "/playlist",         "destination": "https://REPLACE_WITH_YOUR_BACKEND_URL/playlist" },
    { "source": "/search-internet",  "destination": "https://REPLACE_WITH_YOUR_BACKEND_URL/search-internet" },
    { "source": "/api/:path*",       "destination": "https://REPLACE_WITH_YOUR_BACKEND_URL/api/:path*" },
    { "source": "/streams/:path*",   "destination": "https://REPLACE_WITH_YOUR_BACKEND_URL/streams/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
